#!/usr/bin/env python3
"""turdr — a status-aware tmux controller for Gary-managed agent fleets.

Gary (the mailbox) is the only roster: every agent shown comes from
`gary list --json`, and status comes from `gary inbox` (peek-only).
tmux is the only terminal layer: each agent runs in its own tmux pane,
one of which is shown in the main window next to a persistent sidebar.
Selecting an agent swaps its live pane into view (the process is never
restarted by selection); you type into the pane to steer the agent.

Layout (session `gary` by default):

    window "turdr" (main)          parking windows (one per hidden agent)
    +----------+----------------+  +----------------+
    | sidebar  | selected agent |  | another agent  | ...
    | (turdr)  | (live pane)    |  | (live pane)    |
    +----------+----------------+  +----------------+

Panes are tagged with tmux user options (@turdr_agent / @turdr_role) so a
restarted turdr rediscovers everything; no state file of its own.
"""

import argparse
import curses
import json
import os
import re
import shlex
import shutil
import subprocess
import sys
import threading
import time
import tomllib
from concurrent.futures import ThreadPoolExecutor

__version__ = "1.2.1"

REPO_URL = os.environ.get("TURDR_REPO", "https://github.com/Jesse-Lucas1996/turdr")
INSTALL_DIR = os.path.expanduser("~/.local/bin")
CACHE_DIR = os.path.expanduser("~/.local/share/turdr")

NAME_RE = re.compile(r"^[A-Za-z0-9_.@-]+$")
MAIN_WINDOW = "turdr"
# Sentinel agent name for the built-in scratch terminal; the leading ':' can
# never appear in a real Gary agent name (see NAME_RE), so no collisions.
TERM_NAME = ":term"
CMD_TIMEOUT = 15
MAX_AUTO_RESPAWNS = 5

PLACEHOLDER_CMD = (
    "sh -c 'printf \"\\n  turdr: select an agent on the left\\n\"; "
    "while :; do sleep 3600; done'"
)

DEFAULTS = {
    "session": "gary",
    "db": None,                              # None -> gary's own default db
    "poll_interval": 3.0,                    # matches gary watch's cadence
    # Launch template for unlisted agents. The banner matters: `gary watch`
    # prints nothing until a message arrives, and a silent pane reads as broken.
    "default_command":
        "printf '▶ %s — waiting for gary messages\\n' {agent}; "
        "exec gary watch {agent} {db}",
    "default_dir": None,
    "skip_unlisted": False,                  # True -> only manage [agents.*] entries
    "stuck_after": 120,                      # state file older than this -> stuck
    "sidebar_width": 24,   # upper bound; also clamped to 1/3 of the window
    "mouse": True,                           # enable tmux mouse for our session only
    "sender": "turdr",                       # --from used by `turdr send` / the composer
    "auto_respawn": False,                   # respawn exited agents with backoff
}

class TurdrError(Exception):
    pass


# --- config -----------------------------------------------------------------

def load_config(path):
    """Load TOML config over built-in defaults. CLI flags are applied on top
    by the caller, so precedence is: CLI > config file > defaults."""
    cfg = dict(DEFAULTS)
    cfg["agents"] = {}
    if path is None:
        return cfg
    try:
        with open(path, "rb") as f:
            data = tomllib.load(f)
    except FileNotFoundError:
        raise TurdrError(f"config file not found: {path}")
    except OSError as e:
        raise TurdrError(f"cannot read config {path}: {e}")
    except tomllib.TOMLDecodeError as e:
        raise TurdrError(f"invalid TOML in {path}: {e}")

    for key, value in data.items():
        if key == "agents":
            if not isinstance(value, dict):
                raise TurdrError(f"{path}: [agents] must be a table")
            for name, spec in value.items():
                if not NAME_RE.match(name):
                    raise TurdrError(
                        f"{path}: bad agent name {name!r} "
                        f"(allowed: letters, digits, _ . @ -)")
                if not isinstance(spec, dict):
                    raise TurdrError(f"{path}: agents.{name} must be a table")
                unknown = set(spec) - {"command", "dir", "state_file"}
                if unknown:
                    raise TurdrError(
                        f"{path}: agents.{name}: unknown keys {sorted(unknown)}")
                cfg["agents"][name] = dict(spec)
        elif key in DEFAULTS:
            cfg[key] = value
        else:
            print(f"turdr: warning: unknown config key {key!r} ignored",
                  file=sys.stderr)

    validate_config(cfg, source=path)
    return cfg


def validate_config(cfg, source="config"):
    if not isinstance(cfg["session"], str) or not NAME_RE.match(cfg["session"]):
        raise TurdrError(f"{source}: invalid session name {cfg['session']!r}")
    for key in ("poll_interval", "stuck_after", "sidebar_width"):
        if not isinstance(cfg[key], (int, float)) or cfg[key] <= 0:
            raise TurdrError(f"{source}: {key} must be a positive number")
    if not isinstance(cfg["default_command"], str) or not cfg["default_command"].strip():
        raise TurdrError(f"{source}: default_command must be a non-empty string")
    if not NAME_RE.match(str(cfg["sender"])):
        raise TurdrError(f"{source}: invalid sender name {cfg['sender']!r}")


# --- process helpers --------------------------------------------------------

def run_process(cmd, input_text=None):
    """Run an external command with a timeout; the single choke point for
    subprocess use so tests can stub at the process boundary."""
    try:
        return subprocess.run(cmd, input=input_text, capture_output=True,
                              text=True, timeout=CMD_TIMEOUT)
    except FileNotFoundError:
        raise TurdrError(f"{cmd[0]} not found on PATH — install it first")
    except subprocess.TimeoutExpired:
        raise TurdrError(f"{' '.join(cmd[:3])} … timed out after {CMD_TIMEOUT}s")


# --- gary -------------------------------------------------------------------

def gary(cfg, *args, input_text=None):
    cmd = ["gary", *args, "--json"]
    if cfg["db"]:
        cmd += ["--db", cfg["db"]]
    proc = run_process(cmd, input_text=input_text)
    if proc.returncode != 0:
        raise TurdrError(f"gary {args[0]} failed: {proc.stderr.strip() or 'unknown error'}")
    if not proc.stdout.strip():
        return []
    try:
        out = json.loads(proc.stdout)
    except json.JSONDecodeError as e:
        raise TurdrError(f"gary {args[0]}: unparseable JSON output: {e}")
    return out if out is not None else []  # gary prints `null` for empty lists


def send_message(cfg, name, message):
    """Send via `gary send`, body on stdin (never as argv, so leading '-' is
    always safe). Gary requires a registered sender; registering is an
    idempotent add-or-update, and roster() excludes the sender name."""
    gary(cfg, "register", cfg["sender"], "--description",
         "turdr operator console")
    gary(cfg, "send", name, "--from", cfg["sender"], input_text=message)


def roster(cfg):
    """Managed agents: Gary's registry, filtered/enriched by config. Gary is
    the only source of truth for *who exists*; config only says *how to run*."""
    agents = []
    for entry in gary(cfg, "list"):
        name = entry.get("name", "")
        if name == cfg["sender"]:
            continue  # turdr's own mailbox identity, not a managed agent
        if not NAME_RE.match(name):
            print(f"turdr: warning: skipping unsafe agent name {name!r}",
                  file=sys.stderr)
            continue
        spec = cfg["agents"].get(name)
        if spec is None and cfg["skip_unlisted"]:
            continue
        spec = spec or {}
        agents.append({
            "name": name,
            "description": entry.get("description", ""),
            "command": spec.get("command", cfg["default_command"]),
            "dir": spec.get("dir", cfg["default_dir"]),
            "state_file": spec.get("state_file"),
        })
    return agents


def agent_status(cfg, agent):
    """(status, pending_count) from Gary + the optional state file. The state
    file wins when configured and present; otherwise idle/pending straight
    from the inbox. Never fabricates working/stuck without a state file to
    observe. Pane death is overlaid separately (see effective_status)."""
    pending = len(gary(cfg, "inbox", agent["name"]))
    pattern = agent["state_file"]
    if pattern:
        path = os.path.expanduser(pattern.replace("{agent}", agent["name"]))
        try:
            age = time.time() - os.stat(path).st_mtime
            return ("stuck" if age > cfg["stuck_after"] else "working", pending)
        except OSError:
            pass  # no marker file -> agent isn't mid-message; fall through
    return ("pending" if pending else "idle", pending)


def effective_status(status, pane):
    """A dead or missing pane trumps whatever Gary says the agent is doing."""
    return "exited" if pane is None or pane["dead"] else status


def terminal_agent(cfg):
    """The built-in scratch terminal: a plain shell pane managed like an
    agent (swap/respawn) but never part of Gary's roster or status polling."""
    return {"name": TERM_NAME, "description": "scratch terminal",
            "command": os.environ.get("SHELL", "sh"),
            "dir": cfg["default_dir"] or os.path.expanduser("~"),
            "state_file": None}


# --- tmux primitives --------------------------------------------------------

def tmux(*args, check=True):
    proc = run_process(["tmux", *args])
    if check and proc.returncode != 0:
        raise TurdrError(f"tmux {' '.join(args[:4])} failed: {proc.stderr.strip()}")
    return proc


def scan_session(session):
    """One consistent snapshot of our session's tmux state, or None if the
    session doesn't exist. Free-text fields (window names) are last in the
    format string so embedded delimiters can't corrupt parsing."""
    # The window tag deliberately uses a different option name than the pane
    # tag: tmux format lookup resolves pane-scope options over window-scope,
    # so a shared name would let the active pane's tag shadow the window's.
    wins = tmux("list-windows", "-t", f"={session}",
                "-F", "#{window_id}\t#{@turdr_window}\t#{window_name}", check=False)
    if wins.returncode != 0:
        return None
    windows, main_window = {}, None
    for line in wins.stdout.splitlines():
        wid, role, name = line.split("\t", 2)
        windows[wid] = {"name": name, "role": role}
        if role == "main":
            main_window = wid

    panes = tmux("list-panes", "-s", "-t", f"={session}",
                 "-F", "#{pane_id}\t#{window_id}\t#{pane_dead}\t"
                       "#{@turdr_role}\t#{@turdr_agent}")
    sidebar = placeholder = shown = None
    agent_panes = {}
    for line in panes.stdout.splitlines():
        pid, wid, dead, role, agent = line.split("\t", 4)
        pane = {"id": pid, "window": wid, "dead": dead == "1", "agent": agent or None}
        if role == "sidebar" and wid == main_window:
            sidebar = pane
        elif role == "placeholder":
            placeholder = pane
        elif agent:
            agent_panes[agent] = pane
            if wid == main_window:
                shown = pane
    return {"session": session, "windows": windows, "main_window": main_window,
            "sidebar": sidebar, "placeholder": placeholder,
            "agent_panes": agent_panes, "shown": shown}


def tag_pane(pane_id, **options):
    for key, value in options.items():
        tmux("set-option", "-p", "-t", pane_id, f"@turdr_{key}", value)


def launch_command(cfg, agent):
    """Shell command tmux runs for an agent. {agent} becomes the (validated,
    shell-safe) agent name; {db} becomes `--db <path>` when a db is configured
    and nothing otherwise, so default-launched agents watch the same db turdr
    polls. Templates must not add their own quotes around the placeholders."""
    db_arg = ""
    if cfg["db"]:
        db_arg = "--db " + shlex.quote(os.path.expanduser(cfg["db"]))
    cmd = agent["command"].replace("{agent}", shlex.quote(agent["name"]))
    return cmd.replace("{db}", db_arg).strip()


def agent_dir(agent):
    return os.path.expanduser(agent["dir"]) if agent["dir"] else None


def create_agent_pane(cfg, agent):
    """New parking window for an agent, detached (never steals focus).
    remain-on-exit keeps the pane (and its last output) visible if the agent
    crashes, so 'exited' is observable and respawn-in-place is possible."""
    title = "term" if agent["name"] == TERM_NAME else agent["name"]
    args = ["new-window", "-d", "-P", "-F", "#{pane_id}",
            "-t", f"={cfg['session']}:", "-n", title]
    if agent_dir(agent):
        args += ["-c", agent_dir(agent)]
    pane_id = tmux(*args, launch_command(cfg, agent)).stdout.strip()
    tag_pane(pane_id, agent=agent["name"])
    tmux("set-option", "-p", "-t", pane_id, "remain-on-exit", "on")
    tmux("select-pane", "-T", title, "-t", pane_id)
    return pane_id


def adopt_untagged_window(cfg, scan, agent):
    """A single-pane window already named after the agent (e.g. created by an
    older turdr) is adopted by tagging, not duplicated. Multi-pane windows are
    left alone — we don't guess which pane is the agent."""
    for wid, win in scan["windows"].items():
        if win["name"] != agent["name"] or win["role"] or wid == scan["main_window"]:
            continue
        panes = tmux("list-panes", "-t", wid, "-F",
                     "#{pane_id}\t#{@turdr_agent}\t#{@turdr_role}").stdout.splitlines()
        if len(panes) == 1:
            pane_id, tag_agent, tag_role = panes[0].split("\t", 2)
            if tag_agent or tag_role:
                continue  # already ours under another identity — never re-tag
            tag_pane(pane_id, agent=agent["name"])
            tmux("set-option", "-p", "-t", pane_id, "remain-on-exit", "on")
            return pane_id
    return None


def respawn_pane(cfg, agent, pane_id):
    args = ["respawn-pane", "-k", "-t", pane_id]
    if agent_dir(agent):
        args += ["-c", agent_dir(agent)]
    tmux(*args, launch_command(cfg, agent))


# --- layout -----------------------------------------------------------------

def style_main_window(window_id):
    """Pane titles above each pane, bold so they don't drown in the dim
    border color tmux uses by default. Idempotent, window-scoped."""
    tmux("set-option", "-w", "-t", window_id, "pane-border-status", "top")
    tmux("set-option", "-w", "-t", window_id, "pane-border-format",
         " #[bold]#{pane_title}#[default] ")


def effective_sidebar_width(cfg, window_width):
    """The list is a gutter, not the show: never wider than configured and
    never more than a third of the window, with a floor that keeps it usable."""
    if window_width <= 0:
        return int(cfg["sidebar_width"])
    return max(12, min(int(cfg["sidebar_width"]), window_width // 3))


def window_width(target):
    out = tmux("display-message", "-p", "-t", target,
               "#{window_width}", check=False).stdout.strip()
    return int(out) if out.isdigit() else 0


def sidebar_command(cfg, config_path):
    argv = [sys.executable, os.path.abspath(__file__), "sidebar",
            "--session", cfg["session"]]
    if config_path:
        argv += ["-c", os.path.abspath(config_path)]
    if cfg["db"]:
        argv += ["--db", os.path.abspath(cfg["db"])]
    return " ".join(shlex.quote(a) for a in argv)


def ensure_layout(cfg, config_path):
    """Idempotently ensure the session, main window, sidebar and placeholder
    exist. Reuses anything already present; never kills or reorders windows
    it didn't create."""
    session = cfg["session"]
    side_cmd = sidebar_command(cfg, config_path)

    scan = scan_session(session)
    if scan is None:
        proc = tmux("new-session", "-d", "-P", "-F", "#{pane_id}",
                    "-s", session, "-n", MAIN_WINDOW, side_cmd, check=False)
        if proc.returncode == 0:
            pane_id = proc.stdout.strip()
            main = tmux("display-message", "-p", "-t", pane_id,
                        "#{window_id}").stdout.strip()
            tmux("set-option", "-w", "-t", main, "@turdr_window", "main")
            style_main_window(main)
            tag_pane(pane_id, role="sidebar")
            tmux("select-pane", "-T", "turdr", "-t", pane_id)
        elif scan_session(session) is None:
            # Lost a creation race with another turdr? Fine — reuse theirs;
            # anything else is a real failure.
            raise TurdrError(f"tmux new-session failed: {proc.stderr.strip()}")
        scan = scan_session(session)
    if cfg["mouse"]:
        # set-option (unlike other commands) rejects the '=' exact-match
        # prefix; session names are charset-validated so this is unambiguous.
        tmux("set-option", "-t", session, "mouse", "on")

    main = scan["main_window"]
    if main is not None:
        style_main_window(main)
    width = str(effective_sidebar_width(cfg, window_width(main or session)))
    if main is None:
        pane_id = tmux("new-window", "-d", "-P", "-F", "#{pane_id}",
                       "-t", f"={session}:", "-n", MAIN_WINDOW,
                       side_cmd).stdout.strip()
        main = tmux("display-message", "-p", "-t", pane_id,
                    "#{window_id}").stdout.strip()
        tmux("set-option", "-w", "-t", main, "@turdr_window", "main")
        tag_pane(pane_id, role="sidebar")
        style_main_window(main)
        scan = scan_session(session)

    if scan["sidebar"] is None:
        # Sidebar was quit; re-split it back in, left of whatever is shown.
        anchor = scan["shown"] or scan["placeholder"]
        if anchor:
            pane_id = tmux("split-window", "-hb", "-d", "-P", "-F", "#{pane_id}",
                           "-l", width, "-t", anchor["id"], side_cmd).stdout.strip()
        else:  # main window exists but is empty of our panes — take pane 0
            first = tmux("list-panes", "-t", main, "-F",
                         "#{pane_id}").stdout.split()[0]
            pane_id = tmux("split-window", "-hb", "-d", "-P", "-F", "#{pane_id}",
                           "-l", width, "-t", first, side_cmd).stdout.strip()
        tag_pane(pane_id, role="sidebar")
        tmux("select-pane", "-T", "turdr", "-t", pane_id)
        scan = scan_session(session)

    if scan["shown"] is None and scan["placeholder"] is None:
        pane_id = tmux("split-window", "-h", "-d", "-P", "-F", "#{pane_id}",
                       "-t", scan["sidebar"]["id"], PLACEHOLDER_CMD).stdout.strip()
        tag_pane(pane_id, role="placeholder")
        scan = scan_session(session)

    tmux("resize-pane", "-t", scan["sidebar"]["id"], "-x", width)
    return scan


def ensure_agent_panes(cfg, agents):
    """Create (or adopt) a pane for every managed agent that lacks one.
    Returns the set of agent names created this call."""
    scan = scan_session(cfg["session"])
    if scan is None:
        return set()
    created = set()
    for agent in agents:
        if agent["name"] in scan["agent_panes"]:
            continue
        if adopt_untagged_window(cfg, scan, agent) is None:
            create_agent_pane(cfg, agent)
        created.add(agent["name"])
    return created


def show_agent(cfg, agent, focus=False):
    """Swap the agent's live pane into the main window (process untouched).
    The pane previously shown is parked in the agent's old window, which is
    renamed to keep window names meaningful."""
    scan = scan_session(cfg["session"])
    if scan is None:
        raise TurdrError(f"session {cfg['session']} is gone")
    pane = scan["agent_panes"].get(agent["name"])
    if pane is None:
        create_agent_pane(cfg, agent)
        scan = scan_session(cfg["session"])
        pane = scan["agent_panes"][agent["name"]]
    if pane["dead"]:
        respawn_pane(cfg, agent, pane["id"])

    if pane["window"] != scan["main_window"]:
        outgoing = scan["shown"] or scan["placeholder"]
        if outgoing is None:
            tmux("join-pane", "-h", "-d", "-s", pane["id"],
                 "-t", scan["sidebar"]["id"])
            tmux("resize-pane", "-t", scan["sidebar"]["id"], "-x",
                 str(effective_sidebar_width(
                     cfg, window_width(scan["main_window"]))))
        else:
            old_window = pane["window"]
            tmux("swap-pane", "-d", "-s", pane["id"], "-t", outgoing["id"])
            if outgoing["agent"]:
                tmux("rename-window", "-t", old_window, outgoing["agent"])
            else:  # the placeholder is ours; its parking spot is not needed
                tmux("kill-pane", "-t", outgoing["id"])
    if focus:
        tmux("select-pane", "-t", pane["id"])


# --- polling ----------------------------------------------------------------

class Poller(threading.Thread):
    """Background poller: roster, pane scan, per-agent inbox fan-out, and
    (optionally) bounded auto-respawn. The UI thread only reads snapshots;
    all tmux mutations are serialized through tmux_lock."""

    def __init__(self, cfg, tmux_lock):
        super().__init__(daemon=True, name="turdr-poller")
        self.cfg = cfg
        self.tmux_lock = tmux_lock
        self.wake = threading.Event()
        self.stopping = threading.Event()
        self._lock = threading.Lock()
        self._snap = {"agents": [], "statuses": {}, "scan": None, "error": ""}
        self._respawns = {}  # agent -> {"attempts": int, "next_try": float}
        self._pool = ThreadPoolExecutor(max_workers=8,
                                        thread_name_prefix="turdr-inbox")

    def snapshot(self):
        with self._lock:
            return dict(self._snap)

    def poke(self):
        self.wake.set()

    def reset_respawns(self, name):
        with self._lock:
            self._respawns.pop(name, None)

    def stop(self):
        self.stopping.set()
        self.wake.set()

    def run(self):
        while not self.stopping.is_set():
            try:
                self._cycle()
                error = ""
            except TurdrError as e:
                error = str(e)
            with self._lock:
                self._snap["error"] = error
            self.wake.wait(self.cfg["poll_interval"])
            self.wake.clear()
        self._pool.shutdown(wait=False)

    def _cycle(self):
        agents = roster(self.cfg)
        with self.tmux_lock:
            ensure_agent_panes(self.cfg, agents)
            scan = scan_session(self.cfg["session"])
        if scan is None:
            raise TurdrError(f"tmux session {self.cfg['session']} is gone")

        futures = {a["name"]: self._pool.submit(agent_status, self.cfg, a)
                   for a in agents}
        statuses = {}
        for name, fut in futures.items():
            try:
                status, pending = fut.result(timeout=CMD_TIMEOUT + 5)
            except Exception as e:  # surfaced per-agent, poller keeps going
                status, pending = "idle", 0
                with self._lock:
                    self._snap["error"] = f"{name}: {e}"
            pane = scan["agent_panes"].get(name)
            statuses[name] = (effective_status(status, pane), pending)

        if self.cfg["auto_respawn"]:
            self._auto_respawn(agents, scan, statuses)

        with self._lock:
            self._snap.update(agents=agents, statuses=statuses, scan=scan)

    def _auto_respawn(self, agents, scan, statuses):
        now = time.monotonic()
        for agent in agents:
            name = agent["name"]
            pane = scan["agent_panes"].get(name)
            with self._lock:
                if pane is None or not pane["dead"]:
                    self._respawns.pop(name, None)
                    continue
                state = self._respawns.setdefault(
                    name, {"attempts": 0, "next_try": now})
                if state["attempts"] >= MAX_AUTO_RESPAWNS or now < state["next_try"]:
                    continue
                state["attempts"] += 1
                state["next_try"] = now + min(60, 5 * 2 ** state["attempts"])
            with self.tmux_lock:
                respawn_pane(self.cfg, agent, pane["id"])

    def respawn_hint(self, name):
        with self._lock:
            state = self._respawns.get(name)
            if state and state["attempts"] >= MAX_AUTO_RESPAWNS:
                return "respawns exhausted — ⏎ retries"
        return ""


# --- sidebar UI ---------------------------------------------------------------

DOTS = {"idle": "○", "pending": "●", "working": "●", "stuck": "●", "exited": "✗"}
PAIRS = {"idle": 1, "pending": 2, "working": 3, "stuck": 4, "exited": 5}


def sidebar(cfg):
    tmux_lock = threading.Lock()
    poller = Poller(cfg, tmux_lock)
    poller.start()
    try:
        curses.wrapper(_sidebar_loop, cfg, poller, tmux_lock)
    finally:
        poller.stop()


def format_row(name, status, pending, width):
    """Row text after the dot column, adapted to the sidebar width: the name
    always survives, the status word goes first when space runs out (the dot
    color still carries it), then the pending count loses its parentheses."""
    avail = max(4, width - 5)
    count = f" ({pending})" if pending else ""
    stat = f" {status}" if status and width >= 26 else ""
    if len(name) + len(stat) + len(count) > avail:
        stat = ""
    if len(name) + len(count) > avail and pending:
        count = f" {pending}"
    if len(name) + len(count) > avail:
        name = name[:max(2, avail - len(count))]
    return f"{name}{stat}{count}"[:avail].ljust(avail)


def footer_hint(width):
    if width >= 46:
        return "⏎ show · ⇥ type · t term · m msg · r poll · q quit"
    if width >= 24:
        return "⏎ show ⇥ type m msg q quit"
    return "⏎ ⇥ t m q"


def _sidebar_loop(scr, cfg, poller, tmux_lock):
    curses.curs_set(0)
    curses.use_default_colors()
    colors = [curses.COLOR_WHITE, curses.COLOR_YELLOW, curses.COLOR_GREEN,
              curses.COLOR_RED, curses.COLOR_MAGENTA]
    for i, color in enumerate(colors, 1):
        curses.init_pair(i, color, -1)
    try:
        curses.mousemask(curses.BUTTON1_CLICKED)
    except curses.error:
        pass
    scr.timeout(100)

    term = terminal_agent(cfg)
    own_pane = os.environ.get("TMUX_PANE")
    sel, top = 0, 0
    flash = ("", 0.0)
    last_win_w = 0
    next_width_check = 0.0

    def set_flash(text, seconds=4):
        nonlocal flash
        flash = (text, time.monotonic() + seconds)

    def select_entry(entry, focus):
        with tmux_lock:
            show_agent(cfg, entry, focus=focus)
        poller.reset_respawns(entry["name"])
        poller.poke()

    def enforce_width():
        """Keep the sidebar at its fixed width when the *window* resizes
        (tmux rescales panes proportionally), while respecting manual pane
        drags — those change pane width without changing window width."""
        nonlocal last_win_w, next_width_check
        if own_pane is None or time.monotonic() < next_width_check:
            return
        next_width_check = time.monotonic() + 2
        with tmux_lock:
            win_w = window_width(own_pane)
        if not win_w or win_w == last_win_w:
            return
        last_win_w = win_w
        target = effective_sidebar_width(cfg, win_w)
        if scr.getmaxyx()[1] != target:
            with tmux_lock:
                tmux("resize-pane", "-t", own_pane, "-x", str(target),
                     check=False)

    while True:
        enforce_width()
        snap = poller.snapshot()
        agents = snap["agents"]
        statuses = snap["statuses"]
        scan = snap["scan"]
        shown_name = scan["shown"]["agent"] if scan and scan["shown"] else None
        entries = agents + [term]
        sel = max(0, min(sel, len(entries) - 1))

        height, width = scr.getmaxyx()
        rows = max(1, height - 2)
        top = max(0, min(top, sel), sel - rows + 1)

        scr.erase()
        header = (f" turdr {__version__} · {len(agents)}" if width >= 20
                  else f" turdr · {len(agents)}")
        _put(scr, 0, 0, header, width, curses.color_pair(1) | curses.A_BOLD)
        term_pane = scan["agent_panes"].get(TERM_NAME) if scan else None
        for i, entry in enumerate(entries[top:top + rows]):
            name = entry["name"]
            if name == TERM_NAME:
                dead = term_pane is not None and term_pane["dead"]
                dot, pair = ("✗", 5) if dead else ("$", 1)
                label, status, pending = "terminal", "", 0
            else:
                status, pending = statuses.get(name, ("idle", 0))
                dot, pair = DOTS[status], PAIRS[status]
                label = name
            marker = "▸" if name == shown_name else " "
            attr = curses.A_REVERSE if top + i == sel else curses.A_NORMAL
            _put(scr, i + 1, 0, f"{marker}{dot} ", width, curses.color_pair(pair))
            _put(scr, i + 1, 3, format_row(label, status, pending, width), width,
                 attr)
        if not agents:
            _put(scr, 1, 2, "no gary agents", width, curses.A_DIM)

        text, until = flash
        footer = (text if time.monotonic() < until else "") or snap["error"] \
            or footer_hint(width)
        attr = curses.color_pair(4) if snap["error"] and not text else curses.A_DIM
        _put(scr, height - 1, 0, f" {footer}", width, attr)
        scr.refresh()

        try:
            ch = scr.getch()
        except KeyboardInterrupt:
            return
        try:
            if ch in (ord("q"),):
                return
            elif ch in (curses.KEY_UP, ord("k")):
                sel -= 1
            elif ch in (curses.KEY_DOWN, ord("j")):
                sel += 1
            elif ch == ord("r"):
                poller.poke()
            elif ch == ord("t"):
                sel = len(entries) - 1
                select_entry(term, focus=True)
            elif ch in (curses.KEY_ENTER, 10, 13):
                # Enter shows; Enter on the already-shown entry (and the
                # terminal always) moves the keyboard into the pane.
                entry = entries[sel]
                select_entry(entry, focus=entry["name"] in (shown_name, TERM_NAME))
            elif ch in (ord("\t"), curses.KEY_RIGHT, ord("l")):
                select_entry(entries[sel], focus=True)
            elif ch == ord("m") and agents and entries[sel]["name"] != TERM_NAME:
                _compose(scr, cfg, entries[sel], set_flash)
                poller.poke()
            elif ch == curses.KEY_MOUSE:
                try:
                    _, _, my, _, _ = curses.getmouse()
                except curses.error:
                    continue
                row = my - 1
                if 0 <= row < min(rows, len(entries) - top):
                    sel = top + row
                    entry = entries[sel]
                    select_entry(entry, focus=entry["name"] == TERM_NAME)
        except TurdrError as e:
            set_flash(str(e), 6)


def _compose(scr, cfg, agent, set_flash):
    """One-line composer at the footer; sends via `gary send` with the message
    body on stdin (never as an argv, so leading '-' etc. are always safe)."""
    height, width = scr.getmaxyx()
    prompt = f" msg → {agent['name']}: "
    curses.echo()
    curses.curs_set(1)
    scr.timeout(-1)
    try:
        scr.move(height - 1, 0)
        scr.clrtoeol()
        _put(scr, height - 1, 0, prompt, width, curses.A_BOLD)
        scr.refresh()
        raw = scr.getstr(height - 1, min(len(prompt), width - 2), 2000)
    finally:
        curses.noecho()
        curses.curs_set(0)
        scr.timeout(100)
    message = raw.decode("utf-8", errors="replace").strip()
    if not message:
        set_flash("send cancelled")
        return
    try:
        send_message(cfg, agent["name"], message)
        set_flash(f"sent to {agent['name']}")
    except TurdrError as e:
        set_flash(str(e), 6)


def _put(scr, y, x, text, width, attr=curses.A_NORMAL):
    if y < 0 or x >= width:
        return
    try:
        scr.addnstr(y, x, text, max(0, width - x - 1), attr)
    except curses.error:
        pass  # writes into the bottom-right cell during resize are harmless


# --- commands -----------------------------------------------------------------

def cmd_run(cfg, config_path):
    if not shutil.which("tmux"):
        raise TurdrError("tmux not found on PATH")
    if not shutil.which("gary"):
        raise TurdrError("gary not found on PATH — install gary first")
    roster(cfg)  # fail fast on gary/db problems before touching tmux
    scan = ensure_layout(cfg, config_path)
    # Agent panes are created by the sidebar's poller only (single writer):
    # a second creator here would race it and duplicate windows.
    tmux("select-window", "-t", scan["main_window"])
    tmux("select-pane", "-t", scan["sidebar"]["id"])
    if os.environ.get("TMUX"):
        tmux("switch-client", "-t", f"={cfg['session']}")
    else:
        os.execvp("tmux", ["tmux", "attach", "-t", f"={cfg['session']}"])


def cmd_status(cfg, as_json):
    """Read-only report: roster, statuses, pane state. Creates and mutates
    nothing, so it doubles as the smoke check (`--dry-run` of old)."""
    scan = scan_session(cfg["session"]) if shutil.which("tmux") else None
    agents = roster(cfg)
    report = []
    for agent in agents:
        pane = scan["agent_panes"].get(agent["name"]) if scan else None
        status, pending = agent_status(cfg, agent)
        report.append({
            "name": agent["name"],
            "description": agent["description"],
            "status": status,          # gary/state-file view, even pre-launch
            "pane_dead": bool(pane and pane["dead"]),
            "pending": pending,
            "pane": pane["id"] if pane else None,
            "would_create_pane": pane is None,
            "command": launch_command(cfg, agent),
            "dir": agent["dir"],
        })
    if as_json:
        print(json.dumps({"turdr": __version__, "session": cfg["session"],
                          "db": cfg["db"], "agents": report}, indent=2))
        return
    print(f"session: {cfg['session']}  (db: {cfg['db'] or 'gary default'})")
    for r in report:
        pane = r["pane"] or "create"
        where = f" in {r['dir']}" if r["dir"] else ""
        print(f"  {r['name']:<20} {r['status']:<8} pending={r['pending']} "
              f"pane={pane}  cmd: {r['command']}{where}")
    if not report:
        print("  (no managed agents — is anything registered in gary?)")


def cmd_send(cfg, name, message):
    if not NAME_RE.match(name):
        raise TurdrError(f"invalid agent name {name!r}")
    if message is None:
        message = sys.stdin.read().rstrip("\n")
    if not message.strip():
        raise TurdrError("refusing to send an empty message")
    send_message(cfg, name, message)
    print(f"sent to {name}")


def cmd_update():
    """Self-update: git is the source of truth. Pull the checkout this script
    lives in (or a cached clone of REPO_URL) and install to ~/.local/bin."""
    script = os.path.realpath(__file__)
    checkout = _git_toplevel(os.path.dirname(script))
    if checkout:
        if _git_has_upstream(checkout):
            _git(checkout, "pull", "--ff-only")
        else:
            print(f"note: {checkout} has no upstream remote — installing the "
                  "local code as-is.\n"
                  "      to enable pulling updates:  "
                  f"git -C {shlex.quote(checkout)} remote add origin "
                  f"{REPO_URL} && git -C {shlex.quote(checkout)} push -u "
                  "origin HEAD", file=sys.stderr)
        source = os.path.join(checkout, "turdr")
    else:
        if os.path.isdir(os.path.join(CACHE_DIR, ".git")):
            _git(CACHE_DIR, "pull", "--ff-only")
        else:
            os.makedirs(os.path.dirname(CACHE_DIR), exist_ok=True)
            _git(None, "clone", "--depth", "1", REPO_URL, CACHE_DIR)
        source = os.path.join(CACHE_DIR, "turdr")
    if not os.path.isfile(source):
        raise TurdrError(f"updated checkout has no 'turdr' script at {source}")

    target = os.path.join(INSTALL_DIR, "turdr")
    if os.path.realpath(source) != os.path.realpath(target):
        os.makedirs(INSTALL_DIR, exist_ok=True)
        shutil.copy2(source, target)
        os.chmod(target, 0o755)
    new = run_process([sys.executable, source, "version"]).stdout.strip()
    print(f"updated: {new} -> {target}")
    if INSTALL_DIR not in os.environ.get("PATH", "").split(os.pathsep):
        print(f"note: {INSTALL_DIR} is not on your PATH", file=sys.stderr)


def cmd_version():
    line = f"turdr {__version__}"
    checkout = _git_toplevel(os.path.dirname(os.path.realpath(__file__)))
    if checkout:
        proc = run_process(["git", "-C", checkout, "rev-parse", "--short", "HEAD"])
        if proc.returncode == 0:
            line += f" ({proc.stdout.strip()})"
    print(line)


def _git_has_upstream(workdir):
    proc = run_process(["git", "-C", workdir, "rev-parse", "--abbrev-ref",
                        "--symbolic-full-name", "@{u}"])
    return proc.returncode == 0


def _git_toplevel(path):
    try:
        proc = run_process(["git", "-C", path, "rev-parse", "--show-toplevel"])
    except TurdrError:
        return None
    return proc.stdout.strip() if proc.returncode == 0 else None


def _git(workdir, *args):
    cmd = ["git"] + (["-C", workdir] if workdir else []) + list(args)
    proc = run_process(cmd)
    if proc.returncode != 0:
        raise TurdrError(f"git {args[0]} failed: {proc.stderr.strip()}")
    return proc


# --- main ---------------------------------------------------------------------

COMMANDS = {"run", "status", "send", "update", "version", "sidebar"}


def build_parser():
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument("-c", "--config",
                        help="TOML config (default: ./turdr.toml if present)")
    common.add_argument("--db", help="gary db path (overrides config)")
    common.add_argument("--session", help="tmux session name (overrides config)")

    ap = argparse.ArgumentParser(
        prog="turdr",
        description="status-aware tmux controller for Gary agent fleets")
    sub = ap.add_subparsers(dest="cmd", required=True)
    sub.add_parser("run", parents=[common],
                   help="launch/attach the fleet session (default command)")
    p = sub.add_parser("status", parents=[common],
                       help="read-only roster + status report; mutates nothing")
    p.add_argument("--json", action="store_true", help="machine-readable output")
    p = sub.add_parser("send", parents=[common],
                       help="send a gary message to an agent")
    p.add_argument("agent")
    p.add_argument("message", nargs="*",
                   help="message body (reads stdin when omitted)")
    sub.add_parser("update", help=f"self-update from {REPO_URL}")
    sub.add_parser("version", help="print version")
    sub.add_parser("sidebar", parents=[common],
                   help="internal: run the sidebar UI (spawned inside tmux)")
    return ap


def resolve_config(args):
    config_path = getattr(args, "config", None)
    if config_path is None and os.path.exists("turdr.toml"):
        config_path = "turdr.toml"
    cfg = load_config(config_path)
    if getattr(args, "db", None):
        cfg["db"] = args.db
    if getattr(args, "session", None):
        cfg["session"] = args.session
        validate_config(cfg, source="--session")
    return cfg, config_path


def main(argv=None):
    argv = list(sys.argv[1:] if argv is None else argv)
    if argv and argv[0] in ("--version", "-V"):
        argv = ["version"]
    if not argv or (argv[0] not in COMMANDS and argv[0] not in ("-h", "--help")):
        argv = ["run"] + argv  # bare `turdr [flags]` means `turdr run [flags]`
    args = build_parser().parse_args(argv)

    try:
        if args.cmd == "update":
            cmd_update()
        elif args.cmd == "version":
            cmd_version()
        else:
            cfg, config_path = resolve_config(args)
            if args.cmd == "run":
                cmd_run(cfg, config_path)
            elif args.cmd == "status":
                cmd_status(cfg, args.json)
            elif args.cmd == "send":
                cmd_send(cfg, args.agent, " ".join(args.message) or None)
            elif args.cmd == "sidebar":
                sidebar(cfg)
    except TurdrError as e:
        print(f"turdr: {e}", file=sys.stderr)
        sys.exit(1)
    except KeyboardInterrupt:
        sys.exit(130)


if __name__ == "__main__":
    main()
