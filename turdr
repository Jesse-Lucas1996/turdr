#!/usr/bin/env python3
"""turdr — a status-aware tmux controller for Gary-managed agent fleets.

Gary (the mailbox) is cross-agent communication only: the roster comes
from `gary list --json` and the pending/idle signal from `gary inbox`
(peek-only). Steering an agent is direct: every agent owns a whole tmux
window — an interactive terminal session in the agent's working
directory, running whatever command the config gives it (an agent CLI,
a loop script, or just a shell) — and you type into it.

The sidebar is a single pane that HOPS: selecting an agent moves the
sidebar pane into that agent's window (join-pane) and switches there.
Agent windows are normal tmux windows — split them freely; `t` adds a
shell pane inside the selected agent's window, in its directory.

    window "api" (selected)         window "cases" (another agent)
    +--------+-------------------+  +--------------------+
    |sidebar |  agent session    |  |  agent session,    |
    | ○ api ▸|  (its repo/CLI —  |  |  still running     |
    | ● cases|   type to steer)  |  +--------------------+
    | ...    +-------------------+
    |        |  extra shell (t)  |
    +--------+-------------------+

Panes are tagged with tmux user options (@turdr_agent / @turdr_role) so a
restarted turdr rediscovers everything; no state file of its own.
"""

import argparse
import curses
import json
import os
import re
import shlex
import shutil
import subprocess
import sys
import threading
import time
import tomllib
from concurrent.futures import ThreadPoolExecutor

__version__ = "2.0.0"

REPO_URL = os.environ.get("TURDR_REPO", "https://github.com/Jesse-Lucas1996/turdr")
INSTALL_DIR = os.path.expanduser("~/.local/bin")
CACHE_DIR = os.path.expanduser("~/.local/share/turdr")

NAME_RE = re.compile(r"^[A-Za-z0-9_.@-]+$")
SIDEBAR_WINDOW = "turdr"
CMD_TIMEOUT = 15
MAX_AUTO_RESPAWNS = 5

DEFAULTS = {
    "session": "gary",
    "db": None,                              # None -> gary's own default db
    "poll_interval": 3.0,                    # matches gary watch's cadence
    # Launch template for agents without a configured command: an interactive
    # terminal in the agent's directory — start (or configure) the agent CLI
    # from there. Gary is cross-communication, not the face of an agent.
    "default_command":
        "printf '▶ agent {agent} — configure [agents.{agent}] command in "
        "turdr.toml, or work here\\n'; exec \"${SHELL:-sh}\"",
    "default_dir": None,
    "skip_unlisted": False,                  # True -> only manage [agents.*] entries
    "stuck_after": 120,                      # state file older than this -> stuck
    "sidebar_width": 24,   # upper bound; also clamped to 1/3 of the window
    "mouse": True,                           # enable tmux mouse for our session only
    "sender": "turdr",                       # --from used by `turdr send` / the composer
    "auto_respawn": False,                   # respawn exited agents with backoff
}

DEFAULT_USER_CONFIG = """# turdr global config
